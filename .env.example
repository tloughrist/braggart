# Copy to .env and fill in. EXPO_PUBLIC_* vars are embedded in the client bundle.
# The anon key is a public, RLS-gated key — safe on the client (RLS is the real boundary).
#
# Local Supabase (from `supabase start`):
#   - iOS simulator & web:   http://127.0.0.1:54321
#   - Android emulator:      http://10.0.2.2:54321
#   - Physical device (Expo Go): http://<your-machine-LAN-IP>:54321
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key
